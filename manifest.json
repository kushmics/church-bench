{
  "manifest_version": 3,
  "name": "Church Bench",
  "version": "1.0.0",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.goose.com/*",
        "*://*.xvideo.com/*",
        "*://*.banana.com/*",
        "file:///*goose-test.html*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}